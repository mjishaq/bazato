# Web / iOS simulator on same machine:
EXPO_PUBLIC_API_URL=http://localhost:4000
EXPO_PUBLIC_APP_NAME=Bazzato
EXPO_PUBLIC_AUTH_PROVIDER=mock-otp
EXPO_PUBLIC_DEFAULT_SHOP_ID=fresh-mart
EXPO_PUBLIC_KEYCLOAK_ISSUER=http://localhost:8080/realms/bazzato
EXPO_PUBLIC_KEYCLOAK_CLIENT_ID=bazzato-mobile

# Android emulator:
# EXPO_PUBLIC_API_URL=http://10.0.2.2:4000

# Expo Go on a physical phone:
# Use your laptop LAN IP, for example:
# EXPO_PUBLIC_API_URL=http://192.168.1.25:4000
