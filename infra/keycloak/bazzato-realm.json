{
  "realm": "bazzato",
  "enabled": true,
  "registrationAllowed": false,
  "roles": {
    "realm": [
      {
        "name": "customer",
        "description": "Bazzato customer"
      },
      {
        "name": "vendor",
        "description": "Bazzato vendor"
      },
      {
        "name": "admin",
        "description": "Bazzato admin"
      }
    ]
  },
  "clients": [
    {
      "clientId": "bazzato-api",
      "name": "Bazzato API",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "bearerOnly": false,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [],
      "webOrigins": []
    },
    {
      "clientId": "bazzato-mobile",
      "name": "Bazzato Mobile",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "bazzato://*",
        "exp://*",
        "http://localhost:8081/*",
        "https://*.up.railway.app/*"
      ],
      "webOrigins": [
        "*"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "bazzato-api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "bazzato-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "9876543210",
      "enabled": true,
      "firstName": "Bazzato",
      "lastName": "Customer",
      "email": "customer@bazzato.local",
      "emailVerified": true,
      "requiredActions": [],
      "attributes": {
        "phone_number": [
          "9876543210"
        ]
      },
      "credentials": [
        {
          "type": "password",
          "value": "Test@1234",
          "temporary": false
        }
      ],
      "realmRoles": [
        "customer"
      ]
    }
  ]
}
